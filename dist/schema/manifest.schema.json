{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://updates.dreamapp.cc/schema/manifest.schema.json",
  "title": "Dream App Update Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "appId",
    "manifestVersion",
    "defaultChannel",
    "updatedAt",
    "channels"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "appId": {
      "type": "string",
      "minLength": 1
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "defaultChannel": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceRevision": {
      "type": "string"
    },
    "channels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/channel"
      }
    }
  },
  "$defs": {
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "app",
        "tools"
      ],
      "properties": {
        "app": {
          "$ref": "#/$defs/appRelease"
        },
        "tools": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/toolRelease"
          }
        },
        "dreamFm": {
          "$ref": "#/$defs/dreamFm"
        }
      }
    },
    "dreamFm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "liveChannel": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "url",
            "version",
            "updatedAt",
            "ttlSeconds"
          ],
          "properties": {
            "schemaVersion": {
              "type": "integer",
              "minimum": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "minAppVersion": {
              "type": "string"
            },
            "ttlSeconds": {
              "type": "integer",
              "minimum": 60
            },
            "fallback": {
              "type": "string",
              "enum": [
                "embedded",
                "none"
              ]
            }
          }
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "owner",
        "repo"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "github-release"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "downloadSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "url",
        "priority",
        "enabled"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "origin",
            "proxy",
            "mirror"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "priority": {
          "type": "integer"
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "platformArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactName",
        "contentType",
        "size",
        "sha256",
        "sources"
      ],
      "properties": {
        "artifactName": {
          "type": "string",
          "minLength": 1
        },
        "contentType": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "signature": {
          "type": "string"
        },
        "installStrategy": {
          "type": "string",
          "enum": [
            "app-installer",
            "binary",
            "archive"
          ]
        },
        "artifactType": {
          "type": "string",
          "enum": [
            "dmg",
            "exe",
            "zip",
            "tar.xz",
            "raw-binary"
          ]
        },
        "binaries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "executableName": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downloadSource"
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minAppVersion",
        "maxAppVersion"
      ],
      "properties": {
        "minAppVersion": {
          "type": "string",
          "minLength": 1
        },
        "maxAppVersion": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "appRelease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "version",
        "publishedAt",
        "releasePage",
        "platforms"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/sourceRef"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        },
        "releasePage": {
          "type": "string",
          "format": "uri"
        },
        "platforms": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/platformArtifact"
          }
        }
      }
    },
    "toolRelease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "displayName",
        "kind",
        "source",
        "upstreamVersion",
        "recommendedVersion",
        "publishedAt",
        "autoUpdate",
        "required",
        "compatibility",
        "platforms"
      ],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "const": "external-tool"
        },
        "source": {
          "$ref": "#/$defs/sourceRef"
        },
        "upstreamVersion": {
          "type": "string",
          "minLength": 1
        },
        "recommendedVersion": {
          "type": "string",
          "minLength": 1
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "autoUpdate": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        },
        "releasePage": {
          "type": "string",
          "format": "uri"
        },
        "compatibility": {
          "$ref": "#/$defs/compatibility"
        },
        "platforms": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/platformArtifact"
          }
        }
      }
    }
  }
}
